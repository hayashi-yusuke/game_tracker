<h1 class="text-5xl mb-10 text-teal-300">プレイ時間</h1>

<div class="flex text-4xl mb-10 text-indigo-300">
  合計
  <% if @total_time >= 3600 %>
  <%= (@total_time / 3600).to_i %> 時間
  <% end %>
  <%= (@total_time % 3600 / 60).to_i %> 分
</div>

<div class="mt-10 text-lg text-indigo-300 hover:text-amber-300">
  <%= link_to "← 戻る", games_path %>
</div>