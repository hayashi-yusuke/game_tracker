<h1 class="text-5xl mb-10 text-teal-300">ゲーム追加</h1>

<%= form_with model: @game, class: "flex flex-col gap-6 max-w-md" do |f| %>
  <div class="flex flex-col gap-2">
    <%= f.label :name, "ゲーム名", class: "text-lg text-indigo-300" %>
    <%= f.text_field :name, class: "bg-transparent border-b-2 border-indigo-300 text-2xl !text-orange-300 focus:outline-none focus:border-teal-300 py-1" %>
  </div>

  <%= f.submit "追加", class: "mt-4 w-fit text-xl text-violet-300 border border-violet-300 px-6 py-2 hover:text-lime-300 hover:border-lime-300 cursor-pointer" %>
<% end %>

<div class="mt-10 text-lg text-indigo-300 hover:text-amber-300">
  <%= link_to "← 戻る", games_path %>
</div>
